{
  "manifest_version": 3,
  "name": "Piega Parser",
  "version": "0.2.0",
  "description": "Property data parser — extracts listing data from Rightmove and sends it for AI analysis.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Piega — Analyse Property"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "http://localhost:3001/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.rightmove.co.uk/properties/*"],
      "js": ["rightmove/content_script.js"],
      "run_at": "document_idle"
    }
    /* Future domains — uncomment when ready:
    ,{
      "matches": ["*://*.zoopla.co.uk/for-sale/details/*"],
      "js": ["zoopla/content_script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.onthemarket.com/details/*"],
      "js": ["onthemarket/content_script.js"],
      "run_at": "document_idle"
    }
    */
  ]
}
