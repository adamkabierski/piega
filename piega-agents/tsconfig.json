{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"],
      "@fixtures/*": ["./fixtures/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "eval/**/*"],
  "exclude": ["node_modules", "dist"]
}
